{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/YFan945/student-presentation-suite/main/plugins/student-presentation-suite/references/slide-spec.schema.json",
  "title": "Student Presentation Slide Spec",
  "type": "object",
  "additionalProperties": false,
  "required": ["slides"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "presentation_type": { "type": "string", "minLength": 1 },
        "scenario": {
          "enum": [
            "course-report",
            "defense",
            "competition",
            "club-showcase",
            "research-presentation"
          ]
        },
        "audience": {
          "type": "object",
          "additionalProperties": false,
          "required": ["primary", "knowledge_level"],
          "properties": {
            "primary": {
              "enum": ["teacher", "classmates", "judges", "non-specialists", "mixed"]
            },
            "knowledge_level": {
              "enum": ["introductory", "intermediate", "advanced"]
            },
            "grading_focus": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "explanation_depth": {
              "enum": ["plain-language", "balanced", "technical"]
            }
          }
        },
        "workflow_mode": { "enum": ["guided", "fast"] },
        "quality_tier": { "enum": ["basic", "high-score"] },
        "language": { "enum": ["Chinese", "English", "bilingual"] },
        "duration_min": { "type": "number", "exclusiveMinimum": 0 },
        "slide_count": { "type": "integer", "minimum": 1 },
        "format": { "enum": ["individual", "group"] },
        "members": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "course": { "type": "string" },
        "rubric": { "type": "string" },
        "template": { "type": "string" },
        "logo": { "type": "string" },
        "image_source": {
          "enum": [
            "user-assets",
            "web-search",
            "generated",
            "diagram-only",
            "text-only",
            "ask-before-web-search"
          ]
        },
        "output_prefix": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$"
        }
      }
    },
    "generation_controls": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_words_per_slide": { "type": "integer", "minimum": 10, "maximum": 200 },
        "visual_text_ratio": {
          "enum": ["text-led", "balanced", "visual-led", "auto"]
        },
        "speaker_notes": { "type": "boolean" },
        "memorable_lines": { "type": "boolean" },
        "qa_cards": { "type": "boolean" },
        "citation_style": {
          "enum": ["none", "GB-T-7714", "APA", "MLA", "IEEE", "course-required"]
        }
      }
    },
    "revision_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "targets"],
      "properties": {
        "mode": { "enum": ["full", "partial"] },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "integer", "minimum": 1 }
        },
        "instruction": { "type": "string", "minLength": 1 },
        "preserve_untargeted_slides": { "type": "boolean" }
      }
    },
    "source_deck": {
      "type": "string",
      "minLength": 1,
      "description": "Path or label of the existing deck when this spec is used for an improvement workflow."
    },
    "edit_intent": {
      "enum": ["review-fix", "content-rewrite", "visual-redesign", "template-adapt", "rebuild-clean-copy"]
    },
    "review_findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "target", "problem", "fix"],
        "properties": {
          "severity": { "enum": ["Critical", "Major", "Minor"] },
          "target": { "type": "string", "minLength": 1 },
          "problem": { "type": "string", "minLength": 1 },
          "fix": { "type": "string", "minLength": 1 }
        }
      }
    },
    "preserve": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Deck elements that must be preserved, such as template, logo, footer, source citations, or approved content."
    },
    "change_summary_required": {
      "type": "boolean",
      "description": "Whether the PPTX workflow must write outputs/<topic>-change-summary.md."
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "layout",
          "content",
          "timing_sec",
          "owner"
        ],
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "layout": { "type": "string", "minLength": 1 },
          "kind": {
            "enum": [
              "cover",
              "content",
              "section-divider",
              "quotation",
              "references",
              "appendix",
              "qa",
              "closing"
            ]
          },
          "content": {
            "oneOf": [
              { "type": "object" },
              { "type": "array" },
              { "type": "string", "minLength": 1 }
            ]
          },
          "ppt_text": { "type": "string", "minLength": 1 },
          "speaker_notes": { "type": "string", "minLength": 1 },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "claim", "status"],
              "properties": {
                "type": {
                  "enum": [
                    "data",
                    "citation",
                    "case",
                    "comparison",
                    "experiment",
                    "survey",
                    "user-feedback",
                    "project-artifact"
                  ]
                },
                "claim": { "type": "string", "minLength": 1 },
                "source": { "type": "string", "minLength": 1 },
                "date": { "type": "string", "minLength": 1 },
                "status": {
                  "enum": ["verified", "user-provided", "to-verify", "illustrative"]
                }
              }
            }
          },
          "locked_fields": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "enum": ["title", "content", "ppt_text", "layout", "visual", "speaker_notes", "transition"]
            }
          },
          "visual": {
            "type": "object",
            "required": ["type", "purpose"],
            "additionalProperties": false,
            "properties": {
              "type": { "type": "string", "minLength": 1 },
              "purpose": { "type": "string", "minLength": 1 },
              "details": {
                "oneOf": [
                  { "type": "object" },
                  { "type": "array" },
                  { "type": "string" }
                ]
              }
            }
          },
          "note_goal": { "type": "string", "minLength": 1 },
          "transition": { "type": "string", "minLength": 1 },
          "timing_sec": { "type": "integer", "minimum": 1 },
          "owner": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
