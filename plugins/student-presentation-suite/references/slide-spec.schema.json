{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/student-presentation-suite/slide-spec.schema.json",
  "title": "Student Presentation Slide Spec",
  "type": "object",
  "additionalProperties": false,
  "required": ["slides"],
  "properties": {
    "schema_version": { "enum": ["1.0", "2.0"] },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "topic": { "type": "string", "minLength": 1 },
        "presentation_type": { "type": "string", "minLength": 1 },
        "scenario": {
          "enum": ["coursework", "defense", "competition", "club-showcase", "research"]
        },
        "audience": { "type": "string", "minLength": 1 },
        "audience_type": {
          "enum": ["teacher", "classmates", "judges", "non-specialists", "mixed"]
        },
        "audience_depth": { "enum": ["introductory", "standard", "expert"] },
        "language": { "enum": ["Chinese", "English", "bilingual"] },
        "duration_min": { "type": "number", "exclusiveMinimum": 0 },
        "slide_count": { "type": "integer", "minimum": 1 },
        "format": { "enum": ["individual", "group"] },
        "members": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "course": { "type": "string" },
        "rubric": { "type": "string" },
        "structure_mode": {
          "enum": ["problem-solution", "research", "timeline", "comparison", "case-study", "product"]
        },
        "interaction_mode": { "enum": ["beginner", "expert"] },
        "quality_level": { "enum": ["basic", "high-score"] },
        "max_words_per_slide": { "type": "integer", "minimum": 10, "maximum": 120 },
        "max_chinese_chars_per_slide": { "type": "integer", "minimum": 20, "maximum": 240 },
        "visual_text_ratio": { "enum": ["text-led", "balanced", "visual-led"] },
        "include_speaker_notes": { "type": "boolean" },
        "include_key_lines": { "type": "boolean" },
        "citation_style": { "enum": ["none", "classroom", "GB-T-7714", "APA"] },
        "export_formats": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": ["pptx", "pdf", "speaker-notes", "preview", "teleprompter", "quality-report", "revision-manifest"]
          }
        },
        "versioning": { "type": "boolean" },
        "source_material": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1
            }
          ]
        },
        "template": { "type": "string" },
        "logo": { "type": "string" },
        "image_source": {
          "enum": [
            "user-assets",
            "web-search",
            "generated",
            "diagram-only",
            "text-only",
            "ask-before-web-search"
          ]
        },
        "visual_style": { "type": "string", "minLength": 1 },
        "deliverables": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "output_prefix": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$"
        }
      }
    },
    "source_deck": {
      "type": "string",
      "minLength": 1,
      "description": "Path or label of the existing deck when this spec is used for an improvement workflow."
    },
    "edit_intent": {
      "enum": ["review-fix", "content-rewrite", "visual-redesign", "template-adapt", "rebuild-clean-copy"]
    },
    "review_findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "target", "problem", "fix"],
        "properties": {
          "severity": { "enum": ["Critical", "Major", "Minor"] },
          "target": { "type": "string", "minLength": 1 },
          "problem": { "type": "string", "minLength": 1 },
          "fix": { "type": "string", "minLength": 1 }
        }
      }
    },
    "preserve": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Deck elements that must be preserved, such as template, logo, footer, source citations, or approved content."
    },
    "change_summary_required": {
      "type": "boolean",
      "description": "Whether the PPTX workflow must write outputs/<topic>-change-summary.md."
    },
    "evidence_ledger": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "source_type", "locator", "confidence", "used_on_slides"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$" },
          "title": { "type": "string", "minLength": 1 },
          "source_type": {
            "enum": ["user-file", "paper", "book", "website", "dataset", "survey", "experiment", "interview", "case", "other"]
          },
          "locator": { "type": "string", "minLength": 1 },
          "author": { "type": "string" },
          "date": { "type": "string" },
          "confidence": { "enum": ["high", "medium", "low", "unverified"] },
          "used_on_slides": {
            "type": "array",
            "items": { "type": "integer", "minimum": 1 },
            "uniqueItems": true
          },
          "limitation": { "type": "string" }
        }
      }
    },
    "revision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revision_id"],
      "properties": {
        "revision_id": { "type": "string", "minLength": 1 },
        "parent_revision": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "revision_operation": {
      "enum": ["rewrite-slide", "rewrite-section", "change-style", "compress", "expand", "add-evidence"]
    },
    "target_slides": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 },
      "uniqueItems": true
    },
    "target_section": { "type": "string", "minLength": 1 },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "layout",
          "content",
          "timing_sec",
          "owner"
        ],
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "layout": { "type": "string", "minLength": 1 },
          "role": {
            "enum": [
              "opening",
              "background",
              "problem",
              "method",
              "evidence",
              "result",
              "solution",
              "value",
              "limitation",
              "conclusion",
              "qa",
              "closing"
            ]
          },
          "kind": {
            "enum": [
              "cover",
              "content",
              "section-divider",
              "quotation",
              "references",
              "appendix",
              "qa",
              "closing"
            ]
          },
          "content": {
            "oneOf": [
              { "type": "object" },
              { "type": "array" },
              { "type": "string", "minLength": 1 }
            ]
          },
          "claim": { "type": "string", "minLength": 1 },
          "supporting_points": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "maxItems": 6
          },
          "slide_copy": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            ]
          },
          "speaker_notes": { "type": "string", "minLength": 1 },
          "key_line": { "type": "string", "minLength": 1 },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "locked": { "type": "boolean" },
          "lock_reason": { "type": "string", "minLength": 1 },
          "visual": {
            "type": "object",
            "required": ["type", "purpose"],
            "additionalProperties": false,
            "properties": {
              "type": { "type": "string", "minLength": 1 },
              "purpose": { "type": "string", "minLength": 1 },
              "details": {
                "oneOf": [
                  { "type": "object" },
                  { "type": "array" },
                  { "type": "string" }
                ]
              }
            }
          },
          "note_goal": { "type": "string", "minLength": 1 },
          "transition": { "type": "string", "minLength": 1 },
          "timing_sec": { "type": "integer", "minimum": 1 },
          "owner": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
