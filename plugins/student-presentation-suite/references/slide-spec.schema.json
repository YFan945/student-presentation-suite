{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/student-presentation-suite/slide-spec.schema.json",
  "title": "Student Presentation Slide Spec",
  "type": "object",
  "additionalProperties": false,
  "required": ["slides"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "presentation_type": { "type": "string", "minLength": 1 },
        "language": { "enum": ["Chinese", "English", "bilingual"] },
        "duration_min": { "type": "number", "exclusiveMinimum": 0 },
        "slide_count": { "type": "integer", "minimum": 1 },
        "format": { "enum": ["individual", "group"] },
        "members": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "course": { "type": "string" },
        "rubric": { "type": "string" },
        "template": { "type": "string" },
        "logo": { "type": "string" },
        "image_source": {
          "enum": [
            "user-assets",
            "web-search",
            "generated",
            "diagram-only",
            "text-only",
            "ask-before-web-search"
          ]
        },
        "output_prefix": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$"
        }
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "title",
          "layout",
          "content",
          "visual",
          "note_goal",
          "transition",
          "timing_sec",
          "owner"
        ],
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "layout": { "type": "string", "minLength": 1 },
          "content": {
            "oneOf": [
              { "type": "object" },
              { "type": "array" },
              { "type": "string", "minLength": 1 }
            ]
          },
          "visual": {
            "type": "object",
            "required": ["type", "purpose"],
            "additionalProperties": true,
            "properties": {
              "type": { "type": "string", "minLength": 1 },
              "purpose": { "type": "string", "minLength": 1 }
            }
          },
          "note_goal": { "type": "string", "minLength": 1 },
          "transition": { "type": "string", "minLength": 1 },
          "timing_sec": { "type": "integer", "minimum": 1 },
          "owner": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
